name = "neuromod-chat"
main = "src/worker.js"
compatibility_date = "2024-11-01"

# Bundle the demo UI (src/index.html) as a text module so `import INDEX_HTML from "./index.html"`
# works — the whole page is served from GET /.
[[rules]]
type = "Text"
globs = ["**/*.html"]

# ---------------------------------------------------------------------------------------------
# Copy this file to `wrangler.toml` (which is gitignored) and fill in your real values:
#     cp wrangler.toml.example wrangler.toml
#
# Credentials stay as encrypted secrets (NOT in this file, NOT in git):
#     wrangler secret put RUNPOD_API_KEY     # required — used for BOTH endpoints (same key)
#     wrangler secret put API_KEY            # optional — gate the whole demo behind a client key
#
# Tier switch: everyone hits RUNPOD_ENDPOINT_ID (the default). Visiting `/?k=<UNLOCK_KEY>` sets an
# httpOnly cookie and routes that browser to RUNPOD_ENDPOINT_ID_PRO. The PRO endpoint id and the
# unlock key are never sent to the browser (Worker env is server-side; the cookie is httpOnly).
# ---------------------------------------------------------------------------------------------
[vars]
# Default (public) endpoint — served to everyone. e.g. llama-8b.
RUNPOD_ENDPOINT_ID = "your-default-endpoint-id"
# Gated PRO endpoint — served only to browsers that unlocked via /?k=<UNLOCK_KEY>. e.g. gpt-oss-120b.
RUNPOD_ENDPOINT_ID_PRO = "your-pro-endpoint-id"
# Secret string that unlocks the PRO tier: visit /?k=<UNLOCK_KEY>. Pick a long random value.
UNLOCK_KEY = "change-me-to-a-long-random-string"
ALLOW_ORIGIN = "*"
POLL_MS = "300"
# Token budget per tier (Worker sets these; the frontend can't know which model it hit).
MAX_TOKENS_DEFAULT = "1536"   # default/small model (e.g. llama-8b) — plenty long
MAX_TOKENS_PRO = "512"        # PRO/large model (e.g. gpt-oss-120b) — reasonable
# Display label per tier for the UI's "Model" badge (GET /api/model). Display name only — NOT
# the endpoint id or unlock key, so this is safe to expose to the browser.
MODEL_LABEL_DEFAULT = "Llama-3.1-8B"
MODEL_LABEL_PRO = "gpt-oss-120b"
# Optional: override the pack list returned by /api/packs (the UI has its own built-in catalog).
# PACKS = "none,lsd,dmt,cocaine,mdma"
